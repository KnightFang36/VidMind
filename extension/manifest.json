{
  "manifest_version": 3,
  "name": "VidMind",
  "version": "0.1.0",
  "description": "A focused companion sidebar for YouTube.",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["contents/youtube.ts"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open VidMind"
  }
}
