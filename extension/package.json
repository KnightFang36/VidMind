{
  "name": "vidmind-extension",
  "displayName": "VidMind",
  "version": "0.1.0",
  "description": "A focused companion sidebar for YouTube.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "latest",
    "plasmo": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "latest",
    "@types/node": "latest",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.0.0"
  },
  "manifest": {
    "minimum_chrome_version": "116",
    "permissions": ["sidePanel"],
    "host_permissions": ["https://www.youtube.com/*"],
    "action": {
      "default_title": "Open VidMind"
    }
  }
}
